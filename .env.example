# Supabase
SUPABASE_URL=
SUPABASE_KEY=
# Opcional — para scripts apply_*_schema.py (Connection string do Supabase → Database)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[SENHA]@aws-0-....pooler.supabase.com:5432/postgres

# Mercos (opcional — sandbox padrão)
MERCOS_APPLICATION_TOKEN=
MERCOS_COMPANY_TOKEN=
MERCOS_BASE_URL=https://sandbox.mercos.com/api/v1
# Produção (Etapa 6 — tokens do cliente):
# MERCOS_BASE_URL=https://api.mercos.com/api/v1
# MERCOS_ENV=production

# App
FRONTEND_URL=http://localhost:5173
AUTH_RESET_DEBUG=true
JWT_SECRET=gere-uma-chave-longa-e-aleatoria-aqui
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7
# Deploy: URL do front na Vercel (ex. https://xnamai-frontendagent.vercel.app)
# CORS_ORIGINS=

# OpenAI (recomendado — Copiloto 100% inteligente com GPT-4o)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# COPILOT_GPT_ONLY=true

# WhatsApp Meta Cloud API (Etapa 5)
# META_APP_ID=
# META_APP_SECRET=
# META_ACCESS_TOKEN=
# META_PHONE_NUMBER_ID=
# META_WEBHOOK_VERIFY_TOKEN=pulsedesk_whatsapp_verify
# META_API_VERSION=v21.0
# PUBLIC_API_URL=https://xnamai-backendagent.onrender.com

# ETL agendado (Render Cron) — sync Mercos → Supabase sem sobrecarregar a API
# Gere um token longo e use o mesmo no web + nos cron jobs
# ETL_CRON_SECRET=
# Nos crons Render: ETL_BASE_URL=https://xnamai-backendagent.onrender.com/api/etl/run
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM_EMAIL=seu@gmail.com
SMTP_FROM_NAME=PulseDesk
